# Supabase — get these from your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Apple Wallet (Phase 2 — leave empty to use fallback web pass)
# APPLE_TEAM_ID=
# APPLE_PASS_TYPE_ID=
# APPLE_PASS_CERTIFICATE=   # base64-encoded .p12
# APPLE_PASS_CERTIFICATE_PASSWORD=
# APPLE_WWDR_CERTIFICATE=   # base64-encoded Apple WWDR cert

# Google Wallet (Phase 2 — leave empty to use fallback web pass)
# Set GOOGLE_WALLET_PUBLISHED=true ONLY after the issuer clears Google's
# publishing review — until then the native save errors for real customers, so
# the app routes them to the working web card (QR) instead.
# GOOGLE_WALLET_PUBLISHED=
# GOOGLE_WALLET_ISSUER_ID=
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_SERVICE_ACCOUNT_KEY=  # base64-encoded JSON key file

# Stripe — use TEST keys locally; LIVE keys live in Vercel Production only.
# Generate the price ids + webhook secret with: STRIPE_SECRET_KEY=sk_... node scripts/stripe-setup.mjs
# STRIPE_SECRET_KEY=
# STRIPE_PRICE_STARTER=
# STRIPE_PRICE_GROWTH=
# STRIPE_WEBHOOK_SECRET=

# Sentry error monitoring (leave empty to disable — the app no-ops without a DSN)
# NEXT_PUBLIC_SENTRY_DSN=   # the DSN from your Sentry project (client + server)
# SENTRY_ORG=              # build-time: needed only for readable source maps
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=       # build-time source-map upload token (set in Vercel)
